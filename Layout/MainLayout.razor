@inherits LayoutComponentBase

<div class="top-left">
    <button class="menu-button" @onclick="ToggleMenu" aria-label="Menü">☰</button>
    <nav class="menu-panel" style="display:@(isMenuOpen ? "block" : "none")">
        <NavLink class="menu-link" href="">Startseite</NavLink>
        <NavLink class="menu-link" href="verlauf">Verlauf</NavLink>
    </nav>
</div>

<div class="page">
    @Body
</div>

@code {
    private bool isMenuOpen;

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }
}
